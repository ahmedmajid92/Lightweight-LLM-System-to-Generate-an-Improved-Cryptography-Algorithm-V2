# Copy to .env and fill in values.

# OpenAI (fallback — used when OpenRouter is not configured)
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL_FAST=gpt-5-mini
OPENAI_MODEL_QUALITY=gpt-5.2
OPENAI_MODEL_CODE=gpt-5.2-codex
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# OpenRouter (PRIMARY — DeepSeek-R1 for reasoning, V3 for fast tasks)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL_FAST=deepseek/deepseek-chat-v3-0324
OPENROUTER_MODEL_REASONING=deepseek/deepseek-r1

# Local llama.cpp fallbacks (used only when remote calls fail due connection/no internet)
LOCAL_LLM_ENABLED=false
LOCAL_LLM_API_KEY=sk-no-key-required
LOCAL_LLM_TIMEOUT_SECONDS=60
LOCAL_REASONING_BASE_URL=http://127.0.0.1:8081/v1
LOCAL_REASONING_MODEL=DeepSeek-R1-Distill-Qwen-7B
LOCAL_CODE_BASE_URL=http://127.0.0.1:8082/v1
LOCAL_CODE_MODEL=Qwen2.5-Coder-7B-Instruct

# RAG
RAG_USE_EMBEDDINGS=false
RAG_EMBEDDING_PROVIDER=auto
RAG_DENSE_WEIGHT=0.60
RAG_BM25_WEIGHT=0.40
RAG_FINAL_TOP_K=6
RAG_LOCAL_EMBEDDINGS_ENABLED=true
RAG_LOCAL_EMBEDDING_BASE_URL=http://127.0.0.1:8083/v1
RAG_LOCAL_EMBEDDING_MODEL=nomic-embed-text-v1.5
RAG_LOCAL_EMBED_DIM=512
RAG_RERANK_ENABLED=false
RAG_RERANK_BASE_URL=http://127.0.0.1:8084/v1
RAG_RERANK_MODEL=Qwen3-Reranker-0.6B
RAG_RERANK_TOP_N=30

# Project
GLOBAL_SEED=1337
